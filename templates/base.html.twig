<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Bucket-List{% endblock %}</title>

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    >
    <link rel="icon" href="{{ asset("images/favicon.png") }}">
</head>
<body>
<div class="container">


    <header>
        <h1><img src="{{ asset('images/logo.svg') }}" alt="Bucket">Bucket-List</h1>
        {% include 'views/nav/nav.html.twig' %}
    </header>
    <main>
        {% block body %}{% endblock %}
    </main>
    <footer>
        <div>&copy;Bucket-List - {{ "now" | date('Y') }}</div>
    </footer>
</div>
</body>
</html>









